# ===========================================
# Mini Intra Qualite - Variables d'environnement
# ===========================================
# Copier ce fichier en .env et remplir les valeurs
# ATTENTION : ne jamais commiter le fichier .env

# --- Application ---
PUBLIC_APP_NAME="Mini Intra Qualite"
PUBLIC_APP_URL="http://localhost:5173"

# --- PocketBase ---
PUBLIC_POCKETBASE_URL="http://localhost:8090"
PB_ADMIN_EMAIL=""           # Email du compte admin PocketBase
PB_ADMIN_PASSWORD=""        # Mot de passe admin PocketBase (min 12 caracteres)

# --- Securite ---
# Origines autorisees pour CORS (separer par des virgules)
ALLOWED_ORIGINS="http://localhost:5173"
# Duree de session en secondes (defaut : 14 jours)
SESSION_DURATION="1209600"
