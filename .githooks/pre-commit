#!/bin/bash
# ===========================================
# Pre-commit hook — Qualite & Securite
# ===========================================
# Installation : git config core.hooksPath .githooks
#
# Ce hook bloque le commit si :
# - Le code ne passe pas ESLint
# - Le code n'est pas formate avec Prettier
# - Des secrets sont detectes
# - Des console.log sont presents
# - Des fichiers sensibles (.env, credentials) sont stages

set -e

FRONTEND_DIR="frontend"
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "=== Pre-commit : verification qualite & securite ==="

# 1. Bloquer les fichiers sensibles
echo -n "[1/5] Fichiers sensibles... "
SENSITIVE_PATTERNS=".env|credentials|\.pem$|\.key$|\.p12$|id_rsa"
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)
SENSITIVE_FOUND=$(echo "$STAGED_FILES" | grep -iE "$SENSITIVE_PATTERNS" || true)
if [ -n "$SENSITIVE_FOUND" ]; then
  echo -e "${RED}BLOQUE${NC}"
  echo -e "${RED}Fichiers sensibles detectes dans le commit :${NC}"
  echo "$SENSITIVE_FOUND"
  echo "Retirez-les avec : git reset HEAD <fichier>"
  exit 1
fi
echo -e "${GREEN}OK${NC}"

# 2. Scan de secrets (patterns courants)
echo -n "[2/5] Scan de secrets... "
STAGED_CONTENT=$(git diff --cached --diff-filter=ACM -U0 -- '*.ts' '*.svelte' '*.js' '*.json' '*.yml' '*.yaml' 2>/dev/null || true)
SECRET_PATTERNS="password\s*[:=]\s*['\"][^'\"]{8,}|api[_-]?key\s*[:=]\s*['\"]|PRIVATE[_-]?KEY|Bearer\s+[A-Za-z0-9\-._~+/]+=*"
SECRETS_FOUND=$(echo "$STAGED_CONTENT" | grep -iE "$SECRET_PATTERNS" | grep "^+" || true)
if [ -n "$SECRETS_FOUND" ]; then
  echo -e "${RED}BLOQUE${NC}"
  echo -e "${RED}Patterns de secrets detectes :${NC}"
  echo "$SECRETS_FOUND" | head -5
  echo ""
  echo "Si c'est un faux positif, commitez avec : git commit --no-verify"
  exit 1
fi
echo -e "${GREEN}OK${NC}"

# 3. Pas de console.log dans le code TypeScript/Svelte
echo -n "[3/5] console.log... "
STAGED_TS=$(echo "$STAGED_FILES" | grep -E '\.(ts|svelte)$' || true)
if [ -n "$STAGED_TS" ]; then
  CONSOLE_FOUND=""
  for f in $STAGED_TS; do
    if [ -f "$f" ]; then
      MATCH=$(grep -n "console\.log" "$f" 2>/dev/null || true)
      if [ -n "$MATCH" ]; then
        CONSOLE_FOUND="$CONSOLE_FOUND\n  $f:\n$MATCH"
      fi
    fi
  done
  if [ -n "$CONSOLE_FOUND" ]; then
    echo -e "${RED}BLOQUE${NC}"
    echo -e "${RED}console.log detecte :${NC}"
    echo -e "$CONSOLE_FOUND"
    echo ""
    echo "Utilisez console.warn ou console.error pour les messages intentionnels."
    exit 1
  fi
fi
echo -e "${GREEN}OK${NC}"

# 4. ESLint sur les fichiers modifies
echo -n "[4/5] ESLint... "
STAGED_LINTABLE=$(echo "$STAGED_FILES" | grep -E '\.(ts|svelte|js)$' || true)
if [ -n "$STAGED_LINTABLE" ] && [ -d "$FRONTEND_DIR" ]; then
  cd "$FRONTEND_DIR"
  LINT_FILES=$(echo "$STAGED_LINTABLE" | sed "s|^$FRONTEND_DIR/||" | tr '\n' ' ')
  if [ -n "$LINT_FILES" ]; then
    npx eslint $LINT_FILES 2>/dev/null || {
      echo -e "${RED}BLOQUE${NC}"
      echo "Corrigez les erreurs ESLint avant de commiter."
      echo "Correction automatique : pnpm lint:fix"
      exit 1
    }
  fi
  cd ..
fi
echo -e "${GREEN}OK${NC}"

# 5. Prettier sur les fichiers modifies
echo -n "[5/5] Prettier... "
if [ -n "$STAGED_LINTABLE" ] && [ -d "$FRONTEND_DIR" ]; then
  cd "$FRONTEND_DIR"
  FORMAT_FILES=$(echo "$STAGED_LINTABLE" | sed "s|^$FRONTEND_DIR/||" | tr '\n' ' ')
  if [ -n "$FORMAT_FILES" ]; then
    npx prettier --check $FORMAT_FILES 2>/dev/null || {
      echo -e "${YELLOW}FORMAT${NC}"
      echo "Fichiers mal formates. Correction automatique :"
      echo "  pnpm format && git add ."
      exit 1
    }
  fi
  cd ..
fi
echo -e "${GREEN}OK${NC}"

echo ""
echo -e "${GREEN}=== Pre-commit : tout est OK ===${NC}"
